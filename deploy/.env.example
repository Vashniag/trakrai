APP_DOMAIN=gateway.example.com
ACME_EMAIL=ops@example.com

# Internal upstream for the gateway proxy.
LIVE_GATEWAY_UPSTREAM=live-gateway:4000

# Live-gateway runtime settings.
DEVICE_ID=default
# Comma-separated TURN urls let the browser fall back from UDP to TCP.
TURN_SERVER_URL=turn:gateway.example.com:3478?transport=udp,turn:gateway.example.com:3478?transport=tcp

# Coturn public/private addressing when you want TURN relay on the same EC2 host.
# With host networking on Linux EC2, TURN_PRIVATE_IP can stay blank unless you need to override it.
TURN_PUBLIC_IP=
TURN_PRIVATE_IP=
