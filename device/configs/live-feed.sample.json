{
  "log_level": "info",
  "ipc": {
    "socket_path": "/tmp/trakrai-cloud-comm.sock"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "key_prefix": "camera"
  },
  "webrtc": {
    "advertise_relay_candidates": false,
    "excluded_interface_prefixes": ["lo", "docker", "br-", "veth", "virbr", "cni", "flannel"],
    "force_ipv4_candidates": true,
    "stun_servers": ["stun:stun.l.google.com:19302"],
    "turn_servers": [
      {
        "url": "turn:192.168.1.100:3478",
        "username": "trakrai",
        "credential": "trakrai-secret"
      }
    ],
    "framerate_fps": 6
  },
  "composite": {
    "width": 960,
    "height": 540,
    "tile_padding": 8
  },
  "native_pipeline": {
    "enabled": true,
    "encoder": "auto",
    "jpeg_decoder": "auto"
  },
  "stream_source": {
    "enabled": false,
    "transport": "udp-h264-rtp",
    "packet_timeout_ms": 2500,
    "streams": [
      {
        "name": "camera-1-raw",
        "layout_mode": "single",
        "frame_source": "raw",
        "camera_names": ["Camera-1"],
        "host": "127.0.0.1",
        "port": 5611
      },
      {
        "name": "camera-1-processed",
        "layout_mode": "single",
        "frame_source": "processed",
        "camera_names": ["Camera-1"],
        "host": "127.0.0.1",
        "port": 5621
      }
    ]
  }
}
