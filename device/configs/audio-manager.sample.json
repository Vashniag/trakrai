{
  "log_level": "info",
  "device_id": "trakrai-device-001",
  "ipc": {
    "socket_path": "/tmp/trakrai-cloud-comm.sock"
  },
  "queue": {
    "max_pending": 128,
    "status_report_interval_sec": 15,
    "dedupe_window_sec": 60
  },
  "storage": {
    "state_db_path": "/home/hacklab/trakrai-device-runtime/state/audio-manager.sqlite3",
    "cache_dir": "/home/hacklab/trakrai-device-runtime/shared/audio/cache",
    "event_log_path": "/home/hacklab/trakrai-device-runtime/shared/audio/audio-events.jsonl"
  },
  "tts": {
    "backend": "auto",
    "default_language": "en",
    "timeout_sec": 30,
    "voice_map": {
      "en": "en",
      "hi": "hi"
    }
  },
  "playback": {
    "backend": "auto",
    "timeout_sec": 60
  },
  "speaker": {
    "enabled": true,
    "transport": "short-code-http",
    "mapping_file": "/home/hacklab/trakrai-device-runtime/shared/audio/speaker-codes.csv",
    "default_address": "",
    "request_timeout_sec": 2,
    "retry_count": 2,
    "backoff_sec": 1
  }
}
