  "queue": {
    "pending_list": "workflow:cloud:pending",
    "processing_list": "workflow:cloud:processing",
    "retry_zset": "workflow:cloud:retry",
    "dead_letter_list": "workflow:cloud:dead-letter",
    "poll_timeout_sec": 5,
    "retry_sweep_sec": 2,
    "max_attempts": 8
  },
  "storage": {
    "files_root": "/var/lib/trakrai/workflow-comm/files",
    "delete_uploaded_files": false
  }
