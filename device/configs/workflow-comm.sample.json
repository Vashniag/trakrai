{
  "log_level": "info",
  "redis": {
    "host": "127.0.0.1",
    "port": 6379,
    "password": "",
    "db": 0,
    "key_prefix": "workflow"
  },
  "ipc": {
    "socket_path": "/tmp/trakrai-cloud-comm.sock"
  },
  "http": {
    "base_url": "https://dev.trakr.live",
    "device_access_token": "replace-me",
    "request_timeout_sec": 15,
    "upload_timeout_sec": 120,
    "max_request_retries": 3,
    "initial_backoff_ms": 500,
    "max_backoff_sec": 30,
    "user_agent": "trakrai-workflow-comm/1.0"
