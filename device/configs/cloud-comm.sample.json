{
  "log_level": "info",
  "device_id": "default",
  "mqtt": {
    "broker_url": "tcp://192.168.1.100:1883",
    "client_id": "trakrai-device-01",
    "keep_alive_sec": 30
  },
  "ipc": {
    "socket_path": "/tmp/trakrai-cloud-comm.sock"
  },
  "edge": {
    "enabled": true,
    "listen_addr": ":8080",
    "path": "/ws",
    "allowed_origins": [
      "http://127.0.0.1:8080",
      "http://localhost:8080"
    ],
    "webrtc": {
      "ice_servers": [
        {
          "urls": ["turn:192.168.1.100:3478"],
          "username": "trakrai",
          "credential": "trakrai-secret"
        }
      ]
    },
    "ui": {
      "enabled": true,
      "static_dir": "/home/hacklab/trakrai-device-runtime/ui",
      "diagnostics_enabled": true,
      "transport_mode": "edge",
      "cloud_bridge_url": "ws://10.8.0.51:8090/ws",
      "management_service": "runtime-manager"
    }
  },
  "cameras": [
    {
      "name": "LP1-Main",
      "enabled": true
    },
    {
      "name": "LP1-Sec",
      "enabled": true
    },
    {
      "name": "LP2-Main",
      "enabled": true
    }
  ]
}
