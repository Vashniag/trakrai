{
  "log_level": "info",
  "device_id": "trakrai-device-local",
  "ipc": {
    "socket_path": "/tmp/trakrai-cloud-comm.sock"
  },
  "redis": {
    "host": "redis",
    "port": 6379,
    "password": "",
    "db": 0,
    "key_prefix": "camera"
  },
  "storage": {
    "shared_dir": "/home/hacklab/trakrai-device-runtime/shared"
  },
  "buffer": {
    "duration_sec": 600,
    "poll_interval_ms": 100,
