  "recording": {
    "default_frame_rate": 10,
    "default_pre_sec": 5,
    "default_post_sec": 5,
    "max_frame_rate": 25,
    "write_timeout_sec": 60,
    "gstreamer_bin": "gst-launch-1.0"
  },
  "upload": {
    "service_name": "cloud-transfer"
  },
  "cameras": [
    {
      "id": 1,
      "name": "Camera-1",
      "width": 640,
      "height": 480,
      "enabled": true
    }
  ]
