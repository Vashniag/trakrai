{
  "log_level": "info",
  "device_id": "trakrai-device-local",
  "mqtt": {
    "broker_url": "tcp://host.docker.internal:1883",
    "client_id": "trakrai-device-local",
    "keep_alive_sec": 30
  },
  "ipc": {
    "socket_path": "/tmp/trakrai-cloud-comm.sock"
  },
  "edge": {
    "enabled": true,
    "listen_addr": ":8080",
    "path": "/ws",
    "webrtc": {
      "ice_servers": []
    },
    "ui": {
      "enabled": true,
      "static_dir": "/home/hacklab/trakrai-device-runtime/ui",
      "diagnostics_enabled": true,
      "transport_mode": "edge",
      "cloud_bridge_url": "ws://127.0.0.1:8080/ws",
      "management_service": "runtime-manager"
    },
    "rate_limit": {
      "max_command_messages": 40,
      "max_messages": 120,
      "window_sec": 5
    }
  },
  "cameras": [
    {
      "name": "Camera-1",
      "enabled": true
    }
  ]
}
