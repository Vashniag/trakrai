{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@trakrai/design-system/*": ["../../packages/trakrai-design-system/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "eslint.config.mjs"
  ],
  "exclude": ["node_modules"]
}
