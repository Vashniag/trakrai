{
  "name": "@trakrai-workflow/plugins",
  "version": "0.0.1-beta.1",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown && pnpm run build:types && pnpm run build:css",
    "build:css": "pnpm exec tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "tsdown --watch & pnpm exec tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "exports": {
    "./ai": "./src/ai/index.ts",
    "./backup-restore": "./src/backup-restore/index.ts",
    "./blocks": "./src/blocks/index.ts",
    "./code-runner": "./src/code-runner/index.ts",
    "./cron-builder": "./src/cron-builder/index.ts",
    "./email": "./src/email/index.ts",
    "./layout": "./src/layout/index.ts",
    "./runs": "./src/runs/index.ts",
    "./styles.css": "./src/styles.css",
    "./triggers": "./src/triggers/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./ai": {
        "import": "./dist/ai/index.js",
        "types": "./dist/ai/index.d.ts"
      },
      "./backup-restore": {
        "import": "./dist/backup-restore/index.js",
        "types": "./dist/backup-restore/index.d.ts"
      },
      "./blocks": {
        "import": "./dist/blocks/index.js",
        "types": "./dist/blocks/index.d.ts"
      },
      "./code-runner": {
        "import": "./dist/code-runner/index.js",
        "types": "./dist/code-runner/index.d.ts"
      },
      "./cron-builder": {
        "import": "./dist/cron-builder/index.js",
        "types": "./dist/cron-builder/index.d.ts"
      },
      "./email": {
        "import": "./dist/email/index.js",
        "types": "./dist/email/index.d.ts"
      },
      "./layout": {
        "import": "./dist/layout/index.js",
        "types": "./dist/layout/index.d.ts"
      },
      "./runs": {
        "import": "./dist/runs/index.js",
        "types": "./dist/runs/index.d.ts"
      },
      "./styles.css": "./dist/styles.css",
      "./triggers": {
        "import": "./dist/triggers/index.js",
        "types": "./dist/triggers/index.d.ts"
      }
    }
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@ai-sdk/provider": "^3.0.8",
    "@trakrai-workflow/core": "workspace:*",
    "@trakrai-workflow/ui": "workspace:*",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@json-render/react-email": "^0.16.0",
    "@monaco-editor/react": "^4.7.0",
    "cronstrue": "^3.14.0",
    "date-fns": "^4.1.0",
    "fast-deep-equal": "^3.1.3",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "html-to-image": "1.11.11",
    "monaco-editor": "^0.55.1",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "quickjs-emscripten": "^0.32.0",
    "sucrase": "^3.35.1"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@trakrai/design-system": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "@xyflow/react": "^12.0.0",
    "ai": "^6.0.0",
    "inngest": "^4.1.0",
    "lucide-react": "^0.400.0 || ^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/react": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/png-chunks-encode": "^1.0.2",
    "@types/png-chunks-extract": "^1.0.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "ai": "^6.0.141",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6",
    "vitest": "^4.1.2"
  }
}
