{
  "name": "@trakrai-workflow/ui",
  "version": "0.0.1-beta.1",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown && pnpm run build:types && pnpm run build:css && node ../../../scripts/ensure-use-client.mjs dist/index.js dist/fluxery.js dist/ui/flow-context.js dist/ui/sidebar/sidebar-context.js dist/ui/sidebar/use-node-schema.js dist/ui/nodes/labeled-handle.js dist/ui/nodes/schema-node-shell.js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "tsdown --watch & tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fluxery": "./src/fluxery.tsx",
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./fluxery": {
        "import": "./dist/fluxery.js",
        "types": "./dist/fluxery.d.ts"
      },
      "./styles.css": "./dist/styles.css"
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "elkjs": "^0.11.1",
    "fast-deep-equal": "^3.1.3",
    "@trakrai-workflow/core": "workspace:*"
  },
  "peerDependencies": {
    "@trakrai/design-system": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.10.0",
    "@trpc/tanstack-react-query": "^11.10.0",
    "@xyflow/react": "^12.0.0",
    "lucide-react": "^0.400.0 || ^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "superjson": "^2.2.6",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.9",
    "typescript": "^6",
    "vitest": "^4.1.4"
  }
}
