{
  "name": "@trakrai/design-system",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "postcss.config.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown && pnpm run build:types && pnpm run build:css",
    "build:css": "pnpm exec tailwindcss -i ./src/styles/globals.css -o ./dist/globals.css --minify",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "tsdown --watch",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "lucide-react": "^0.400.0 || ^1.0.0",
    "next-themes": "^0.4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "7.72.0"
  },
  "peerDependenciesMeta": {
    "next-themes": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.2.1",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.9",
    "typescript": "^6"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./globals.css": "./dist/globals.css",
      "./postcss.config": "./postcss.config.mjs",
      "./lib/*": {
        "import": "./dist/lib/*.js",
        "types": "./dist/lib/*.d.ts"
      },
      "./components/*": {
        "import": "./dist/components/*.js",
        "types": "./dist/components/*.d.ts"
      },
      "./hooks/*": {
        "import": "./dist/hooks/*.js",
        "types": "./dist/hooks/*.d.ts"
      }
    }
  }
}
