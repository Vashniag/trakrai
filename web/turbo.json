{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"],
      "env": [
        "DATABASE_URL",
        "NODE_ENV",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "MICROSOFT_TENANT_ID",
        "SKIP_ENV_VALIDATION",
        "VERCEL_URL",
        "PORT",
        "EMAIL_SENDER_ADDRESS",
        "SMTP_SERVER",
        "SMTP_USER",
        "SMTP_PASSWORD",
        "NEXT_PUBLIC_TRAKRAI_DEVICE_ID",
        "NEXT_PUBLIC_TRAKRAI_DEVICE_TRANSPORT_MODE",
        "NEXT_PUBLIC_TRAKRAI_CLOUD_BRIDGE_URL",
        "NEXT_PUBLIC_TRAKRAI_EDGE_BRIDGE_URL",
        "NEXT_PUBLIC_TRAKRAI_ENABLE_DIAGNOSTICS",
        "NEXT_PUBLIC_LIVE_GATEWAY_WS_URL",
        "NEXT_PUBLIC_LIVE_FEEDER_WS_URL",
        "NEXT_PUBLIC_MEDIATOR_WS_URL",
        "NEXT_PUBLIC_LIVE_GATEWAY_HTTP_URL",
        "NEXT_PUBLIC_LIVE_FEEDER_HTTP_URL",
        "NEXT_PUBLIC_MEDIATOR_HTTP_URL"
      ]
    },
    "lint": {
      "cache": false,
      "dependsOn": ["^build", "^lint"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^test"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": ["NODE_ENV"],
  "globalDependencies": ["tsconfig.json", "package.json"]
}
