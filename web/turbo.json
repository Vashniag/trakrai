{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"],
      "env": [
        "DATABASE_URL",
        "NODE_ENV",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "MICROSOFT_TENANT_ID",
        "SKIP_ENV_VALIDATION",
        "VERCEL_URL",
        "PORT",
        "EMAIL_SENDER_ADDRESS",
        "SMTP_SERVER",
        "SMTP_USER",
        "SMTP_PASSWORD",
        "STORAGE_PROVIDER",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "S3_BUCKET_NAME",
        "AZURE_STORAGE_ACCOUNT_NAME",
        "AZURE_STORAGE_ACCOUNT_KEY",
        "AZURE_STORAGE_CONTAINER_NAME",
        "MINIO_ACCESS_KEY",
        "MINIO_SECRET_KEY",
        "MINIO_BUCKET_NAME",
        "MINIO_ENDPOINT",
        "MINIO_DEVICE_ENDPOINT",
        "MINIO_REGION",
        "TRAKRAI_PACKAGE_RELEASE_TOKEN",
        "NEXT_PUBLIC_TRAKRAI_DEVICE_ID",
        "NEXT_PUBLIC_TRAKRAI_DEVICE_TRANSPORT_MODE",
        "NEXT_PUBLIC_TRAKRAI_CLOUD_BRIDGE_URL",
        "NEXT_PUBLIC_TRAKRAI_EDGE_BRIDGE_URL",
        "NEXT_PUBLIC_TRAKRAI_RUNTIME_CONFIG_URL",
        "NEXT_PUBLIC_TRAKRAI_LOCAL_DEVICE_HTTP_PORT",
        "NEXT_PUBLIC_TRAKRAI_CLOUD_API_URL",
        "NEXT_PUBLIC_TRAKRAI_CLOUD_GATEWAY_BASE_URL",
        "NEXT_PUBLIC_TRAKRAI_ENABLE_DIAGNOSTICS",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL"
      ]
    },
    "lint": {
      "cache": false,
      "dependsOn": ["^build", "^lint"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^test"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "MICROSOFT_TENANT_ID",
    "SKIP_ENV_VALIDATION",
    "VERCEL_URL",
    "PORT",
    "EMAIL_SENDER_ADDRESS",
    "SMTP_SERVER",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "STORAGE_PROVIDER",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION",
    "S3_BUCKET_NAME",
    "AZURE_STORAGE_ACCOUNT_NAME",
    "AZURE_STORAGE_ACCOUNT_KEY",
    "AZURE_STORAGE_CONTAINER_NAME",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "MINIO_BUCKET_NAME",
    "MINIO_ENDPOINT",
    "MINIO_DEVICE_ENDPOINT",
    "MINIO_REGION",
    "TRAKRAI_PACKAGE_RELEASE_TOKEN",
    "NEXT_PUBLIC_TRAKRAI_DEVICE_ID",
    "NEXT_PUBLIC_TRAKRAI_DEVICE_TRANSPORT_MODE",
    "NEXT_PUBLIC_TRAKRAI_CLOUD_BRIDGE_URL",
    "NEXT_PUBLIC_TRAKRAI_EDGE_BRIDGE_URL",
    "NEXT_PUBLIC_TRAKRAI_RUNTIME_CONFIG_URL",
    "NEXT_PUBLIC_TRAKRAI_LOCAL_DEVICE_HTTP_PORT",
    "NEXT_PUBLIC_TRAKRAI_CLOUD_API_URL",
    "NEXT_PUBLIC_TRAKRAI_CLOUD_GATEWAY_BASE_URL",
    "NEXT_PUBLIC_TRAKRAI_ENABLE_DIAGNOSTICS",
    "NEXT_PUBLIC_BASE_URL",
    "NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL"
  ],
  "globalDependencies": ["tsconfig.json", "package.json"]
}
